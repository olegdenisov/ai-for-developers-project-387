{
  "name": "calendar-booking",
  "version": "1.0.0",
  "private": true,
  "description": "Calendar Booking System - Turborepo monorepo with Fastify, React, and TypeSpec",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "generate:openapi": "tsp compile main.tsp --emit @typespec/openapi3",
    "generate:types": "openapi-typescript tsp-output/openapi.json -o packages/shared-types/src/index.ts --makePathsEnum",
    "generate:client": "openapi-generator-cli generate -g typescript-fetch -i tsp-output/openapi.json -o packages/api-client/src --additional-properties=supportsES6=true,npmName=@calendar-booking/api-client,withInterfaces=true",
    "generate:all": "npm run generate:openapi && npm run generate:types && npm run generate:client",
    "db:migrate": "turbo run db:migrate",
    "db:generate": "turbo run db:generate",
    "db:seed": "turbo run db:seed",
    "db:studio": "turbo run db:studio",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:logs": "docker-compose -f docker/docker-compose.yml logs -f",
    "mock:up": "docker-compose -f docker/docker-compose.mock.yml up -d",
    "mock:down": "docker-compose -f docker/docker-compose.mock.yml down",
    "mock:logs": "docker-compose -f docker/docker-compose.mock.yml logs -f",
    "start:dev": "./start-dev.sh",
    "start:mock": "pnpm mock:up && pnpm --filter web dev --mode mock",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@typespec/compiler": "1.10.0",
    "@typespec/http": "1.10.0",
    "@typespec/rest": "0.80.0",
    "@typespec/openapi3": "1.10.0",
    "@openapitools/openapi-generator-cli": "2.31.0",
    "openapi-typescript": "7.13.0",
    "turbo": "2.5.0",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}