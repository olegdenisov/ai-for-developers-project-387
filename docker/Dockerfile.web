# ==================== DEVELOPMENT ====================
FROM node:24-alpine AS development

WORKDIR /app

COPY apps/web/package*.json ./
RUN npm install

COPY apps/web/ ./

EXPOSE 5173

CMD ["npm", "run", "dev"]

# ==================== PRODUCTION ====================
FROM node:24-alpine AS production

WORKDIR /app

COPY apps/web/package*.json ./
RUN npm ci --only=production

COPY apps/web/ ./
RUN npm run build

EXPOSE 5173

CMD ["npm", "run", "preview"]
